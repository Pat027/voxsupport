# voxsupport — copy to .env and fill in

# LLM providers — at least one required. Priority order (first match wins):
#   1. LOCAL_LLM_BASE_URL — local vLLM / OpenAI-compatible server (fastest)
#   2. ANTHROPIC_API_KEY
#   3. OPENAI_API_KEY

# Local LLM via vLLM (sub-1s TTFT path). Start with:
#   docker compose --profile local-llm up -d vllm
# then uncomment the lines below.
# LOCAL_LLM_BASE_URL=http://localhost:8002/v1
# LOCAL_LLM_MODEL=openai/Qwen/Qwen3-4B-Instruct-2507
# LOCAL_LLM_TIMEOUT_S=8

# Fast path: merge classify + response into a single function-calling call.
# Recommended with LOCAL_LLM_BASE_URL set (local vLLM). Cloud works too but
# the latency win is smaller.
# VOXSUPPORT_FAST_PATH=1

# If you want Kyutai STT/TTS on a specific GPU (default cuda:0). Set this to
# cuda:1 if you run vLLM on cuda:0.
# KYUTAI_DEVICE=cuda:0

# If vLLM must run on a non-default GPU (docker-compose env override).
# VLLM_CUDA_DEVICES=1

# Cloud fallback / alternative providers:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse self-hosted keys (generated in Langfuse UI at http://localhost:3000)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Twilio (optional, week 5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Logging
LOG_LEVEL=INFO
