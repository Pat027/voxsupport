# voxsupport — copy to .env and fill in

# LLM providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse self-hosted keys (generated in Langfuse UI at http://localhost:3000)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Twilio (optional, week 5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Logging
LOG_LEVEL=INFO
